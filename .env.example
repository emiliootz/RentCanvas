# =============================================================================
# RentCanvas – Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# ----- PostgreSQL -----
# Local dev example: postgresql://postgres:password@localhost:5432/rentcanvas
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ----- Clerk (Authentication) -----
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect paths (do not change these unless you restructure routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth-redirect
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth-redirect

# ----- Stripe -----
# Get these from https://dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."

# Webhook secret – from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET="whsec_..."

# ----- App Config -----
# The base URL for this app (used in emails, invite links, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# The Clerk userId of the single admin/landlord account.
# Set this after you create your admin account in Clerk.
ADMIN_CLERK_USER_ID=""
